# ============================================
# О-БАНК: Пример файла окружения
# ============================================
# Скопируй этот файл как .env и заполни своими значениями
# Файл .env НИКОГДА не должен попадать в Git!
# ============================================

# ============================================
# 🎯 РЕЖИМ РАБОТЫ
# ============================================
# test = тестовый сервер
# production = боевой сервер
MODE=test

# ============================================
# 🤖 DISCORD BOT
# ============================================
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=1522296397465129101
DISCORD_CLIENT_SECRET=your_client_secret_here

# ============================================
# 🎯 DISCORD SERVERS
# ============================================

# Тестовый сервер
TEST_GUILD_ID=1513622354700406824
TEST_CHANNEL_ID=1522302800980082779
TEST_ROLE_ID=1522303624133476352

# Боевой сервер
PROD_GUILD_ID=1501117509527535737
PROD_CHANNEL_ID=your_prod_channel_id
PROD_ROLE_ID=your_prod_role_id

# ============================================
# 🗄️ SUPABASE (База данных)
# ============================================
SUPABASE_URL=https://nznidzhaxsnlhnjmnpld.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# ============================================
# 🌐 ВЕБ-САЙТ
# ============================================
SITE_URL=https://o-bank-gov.github.io
OAUTH_REDIRECT_URI=https://o-bank-gov.github.io/callback.html

# ============================================
# 🏦 РЕКВИЗИТЫ БАНКА
# ============================================
BANK_NAME=О-Банк
BANK_OGRN=1037700000777
BANK_ADDRESS=г. Санкт-Петербург, ул. Неглинная, д. 12
BANK_PHONE=+79065815940

# ============================================
# ⏰ ГРАФИК РАБОТЫ (МСК)
# ============================================
WORK_HOURS_START=08:00
WORK_HOURS_END_MON_THU=18:00
WORK_HOURS_END_FRI=17:30
WORK_DAYS=Mon,Tue,Wed,Thu,Fri

# ============================================
# 📄 ПУТИ К ФАЙЛАМ
# ============================================
CONTRACTS_DIR=./contracts
SIGNATURES_DIR=./assets/signatures
